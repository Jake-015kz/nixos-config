{
  "React Interface Component": {
    "prefix": "rfc",
    "body": [
      "import classNames from \"classnames\"",
      "import \"./${TM_FILENAME_BASE}.scss\"",
      "",
      "interface ${TM_FILENAME_BASE}Props {",
      "  className?: string",
      "  children?: React.ReactNode",
      "}",
      "",
      "const ${TM_FILENAME_BASE} = ({ className, children }: ${TM_FILENAME_BASE}Props) => {",
      "  return (",
      "    <div className={classNames(\"${1:class-name}\", className)}>",
      "      ${0:children}",
      "    </div>",
      "  )",
      "}",
      "",
      "export default ${TM_FILENAME_BASE}"
    ]
  },
  "useState": {
    "prefix": "us",
    "body": [
      "const [${1:state}, set${1/(.*)/${1:/capitalize}/}] = useState(${2:initialValue})"
    ]
  },
  "useEffect": {
    "prefix": "ue",
    "body": ["useEffect(() => {", "  $0", "}, [${1:dependencies}])"]
  },

  "Console Log": {
    "prefix": "clg",
    "body": ["console.log(\"🚀 ${1:var}:\", ${1:var})"],
    "description": "Лог с ракетой и именем переменной"
  },
  "JSX Comment": {
    "prefix": "rcom",
    "body": ["{/* ${0:comment} */}"],
    "description": "Комментарий внутри JSX"
  },
  "Lucide Icon": {
    "prefix": "licon",
    "body": [
      "<${1:IconName} size={${2:24}} className={classNames(\"$0\", className)} />"
    ],
    "description": "Быстрая вставка иконки (Lucide и др.)"
  }
}
